{
  "name": "LawApp(Template)",
  "version": "1.0.0",
  "auth": "OrangeLan",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/ts/frontend.tsx",
    "build": "bun build ./src/pages/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/ts/frontend.tsx",
    "cap:sync": "cap sync android",
    "cap:run": "cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest",
    "@capacitor/cli": "^7.4.4"
  }
}